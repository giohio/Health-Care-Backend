# ==========================================
# GLOBAL INFRASTRUCTURE CONFIGURATION
# ==========================================

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# RabbitMQ Configuration
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=your_rabbitmq_password_here

# JWT Security (Must match kong.yml for RS256)
# These are used by Auth Service
# JWT_ISSUER=healthcare-system-issuer
# JWT_SECRET_KEY=super-secret-key-123456

# Service Ports (Internal - keep at 8000 as standardized)
AUTH_SERVICE_PORT=3000
PATIENT_SERVICE_PORT=3000
DOCTOR_SERVICE_PORT=3000
APPOINTMENT_SERVICE_PORT=3000

# Gateway Ports
KONG_PROXY_PORT=3000
KONG_ADMIN_PORT=3001

# VNPAY Configuration
VNPAY_TMN_CODE=your_vnpay_tmn_code_here
VNPAY_HASH_SECRET=your_vnpay_hash_secret_here

# SMTP Email Configuration (for Notification Service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=Your App Name <>
